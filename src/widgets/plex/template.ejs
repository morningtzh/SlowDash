<% if (config.type === 'recently_added') { %>
  <!-- Grid Layout (e.g. 5x5) -->
  <div class="relative w-full h-full rounded-2xl overflow-hidden bg-white border-2 border-black p-3 flex flex-col">
    <div class="mb-3 flex justify-between items-end">
      <span class="text-xs font-black tracking-widest uppercase">Plex</span>
      <span class="text-[10px] text-gray-500 font-bold uppercase">Recently Added</span>
    </div>
    <div class="flex-grow grid grid-cols-5 gap-3">
      <% for (let i = 0; i < Math.min(posters.length, 25); i++) { %>
        <div class="bg-gray-200 rounded-lg overflow-hidden bg-cover bg-center grayscale shadow-sm border border-gray-300" style="background-image: url('<%= posters[i] %>'); padding-bottom: 150%;"></div>
      <% } %>
    </div>
  </div>
<% } else if (config.type === 'random_poster') { %>
  <!-- Random Poster / Single Poster (e.g. 2x3) -->
  <div class="relative w-full h-full rounded-2xl overflow-hidden bg-white border-2 border-black p-2 flex flex-col">
    <div class="mb-2 text-center">
      <span class="text-[9px] text-gray-500 font-black tracking-widest uppercase">Movie of the day</span>
    </div>
    <div class="flex-grow bg-cover bg-center grayscale rounded-xl border border-gray-200" style="background-image: url('<%= posters[0] %>');"></div>
  </div>
<% } else { %>
  <!-- Default / Background Layout -->
  <div class="relative w-full h-full rounded-2xl overflow-hidden bg-black flex flex-col items-center justify-center border-2 border-black">
    <% if (error) { %>
      <div class="text-white font-bold"><%= error %></div>
    <% } else if (posters && posters.length > 0) { %>
      <div class="absolute inset-0 bg-cover bg-center grayscale opacity-80 mix-blend-screen" style="background-image: url('<%= posters[0] %>'); filter: grayscale(100%) contrast(1.2) brightness(0.9);"></div>
      <div class="absolute bottom-3 right-3">
        <span class="bg-white text-black text-[10px] px-2 py-0.5 rounded-sm font-black tracking-widest border border-black shadow">PLEX</span>
      </div>
    <% } else { %>
      <div class="text-white font-bold">No Media</div>
    <% } %>
  </div>
<% } %>
