<% if (config.type === 'recently_added') { %>
  <!-- Type: recently_added (e.g. 5x1, 5x2) -->
  <div class="w-full h-full p-4 flex flex-col relative bg-white">
    <div class="text-[10px] text-gray-500 font-bold uppercase mb-3 tracking-widest flex justify-between">
      <span>Plex Recently Added</span>
    </div>
    <div class="flex-grow grid grid-cols-5 gap-4">
      <% 
        let posterCount = 5;
        if (config.size === '5x2') posterCount = 10;
        if (config.size === '5x3') posterCount = 15;
      %>
      <% for (let i = 0; i < Math.min(posters.length, posterCount); i++) { %>
        <div class="bg-cover bg-center grayscale shadow-sm border border-gray-300 rounded-lg aspect-[2/3]" style="background-image: url('<%= posters[i] %>');"></div>
      <% } %>
    </div>
  </div>
<% } else if (config.type === 'poster_wall') { %>
  <!-- Type: poster_wall -->
  <div class="relative w-full h-full p-4 overflow-hidden flex flex-col justify-center items-center">
    <div class="absolute top-4 left-4 bg-white text-black px-2 py-0.5 text-[10px] font-black tracking-widest uppercase rounded border-2 border-black shadow-sm z-50">Poster Wall</div>
    <%
      let count = parseInt(config.count) || 6;
      let arrangement = config.arrangement || 'overlap';
      let gap = 'gap-4';
      if (arrangement === 'compact') gap = 'gap-1';
      if (arrangement === 'loose') gap = 'gap-6';
      
      // Calculate pixel dimensions of the widget
      let cols = 2, rows = 2;
      const match = (config.size || '').match(/(\d+)x(\d+)/);
      if (match) {
        cols = parseInt(match[1]);
        rows = parseInt(match[2]);
      }
      let wPx = cols * 184 + (cols - 1) * 20;
      let hPx = rows * 184 + (rows - 1) * 20;
      let area = wPx * hPx;
      
      // Dynamically calculate poster width based on area and count
      // Aspect ratio is 2:3, so posterArea = 1.5 * width^2
      let calculatedWidth;
      if (arrangement === 'overlap') {
        // In overlap mode, posters stack, so their size shouldn't shrink with count.
        // We make them take up 60% of the smallest dimension of the widget.
        calculatedWidth = Math.floor(Math.min(wPx, hPx) * 0.6);
      } else {
        // In grid mode, they must fit side-by-side, so size depends on count and area.
        calculatedWidth = Math.floor(Math.sqrt((area * 0.6) / (1.5 * count)));
      }
      
      let baseClasses = "bg-cover bg-center grayscale shadow-lg border-2 border-black rounded-lg aspect-[2/3]";
      
      if (arrangement === 'overlap') {
    %>
        <!-- Overlap layout -->
        <div class="relative w-full h-full">
          <% 
            // Calculate max safe percentages so they don't get completely clipped
            let maxLeft = Math.max(0, ((wPx - calculatedWidth) / wPx) * 100);
            let maxTop = Math.max(0, ((hPx - calculatedWidth * 1.5) / hPx) * 100);
            let centerLeft = maxLeft / 2;
            let centerTop = maxTop / 2;
            
            // Create a shuffled array of z-indexes so layering is completely random
            let renderCount = Math.min(posters.length, count);
            let zIndexes = Array.from({length: renderCount}, (_, i) => i);
            zIndexes.sort(() => 0.5 - Math.random());
            
            for (let i = 0; i < renderCount; i++) { 
               let rotation = (Math.random() * 40 - 20).toFixed(1);
               
               // Distribute evenly in a circle to completely avoid clumping
               let angle = (i / renderCount) * Math.PI * 2;
               // Add a slight random jitter to the angle
               angle += (Math.random() - 0.5) * 0.5; 
               
               // Push them mostly to the outer edges (distance 0.6 to 1.0 from center)
               // except the first one which stays near the center
               let distance = i === 0 ? (Math.random() * 0.2) : (0.6 + Math.random() * 0.4);

               let left = (centerLeft + Math.cos(angle) * centerLeft * distance).toFixed(1);
               let top = (centerTop + Math.sin(angle) * centerTop * distance).toFixed(1);
               
               // Add slight size variation (0.80x to 1.20x) for depth effect
               let scale = 0.8 + Math.random() * 0.4;
               let finalWidth = Math.floor(calculatedWidth * scale);
          %>
            <div class="<%= baseClasses %> absolute shadow-xl" 
                 style="width: <%= finalWidth %>px; background-image: url('<%= posters[i] %>'); left: <%= left %>%; top: <%= top %>%; transform: rotate(<%= rotation %>deg); z-index: <%= zIndexes[i] %>;">
            </div>
          <% } %>
        </div>
    <% } else { %>
        <!-- Flex grid layout -->
        <div class="flex flex-wrap justify-center content-center <%= gap %> w-full h-full mt-6">
          <% for (let i = 0; i < Math.min(posters.length, count); i++) { %>
            <div class="<%= baseClasses %>" style="width: <%= calculatedWidth %>px; background-image: url('<%= posters[i] %>');"></div>
          <% } %>
        </div>
    <% } %>
  </div>
<% } else if (config.type === 'background') { %>
  <!-- Type: background (e.g. 5x4, 5x7) -->
  <div class="relative w-full h-full bg-white flex items-center justify-center">
    <% if (posters && posters.length > 0) { %>
      <div class="absolute inset-0 bg-cover bg-center mix-blend-multiply opacity-20" style="background-image: url('<%= posters[0] %>'); filter: grayscale(100%) contrast(1.2);"></div>
      <div class="absolute bottom-4 right-4 bg-white text-black px-2 py-0.5 text-[9px] font-black tracking-widest uppercase rounded-sm border-2 border-black">PLEX</div>
    <% } else { %>
      <div class="text-black font-bold">No Media</div>
    <% } %>
  </div>
<% } else { %>
  <!-- Type: poster (e.g. 2x3, 2x4) -->
  <% if (posters && posters.length > 0) { %>
    <div class="relative w-full h-full bg-cover bg-center overflow-hidden" style="background-image: url('<%= posters[0] %>'); filter: grayscale(100%) contrast(1.25) brightness(0.9);">
      <div class="absolute bottom-0 left-0 right-0 h-1/3 bg-gradient-to-t from-black to-transparent flex items-end p-4">
        <span class="text-[10px] font-black uppercase tracking-widest text-white">Movie of the day</span>
      </div>
    </div>
  <% } else { %>
    <div class="relative w-full h-full flex flex-col justify-center items-center bg-gray-100 p-4 text-center">
      <span class="text-xs font-bold text-gray-500 uppercase">Plex Poster</span>
      <span class="text-sm font-bold text-black mt-2"><%= error || 'No Posters' %></span>
    </div>
  <% } %>
<% } %>
