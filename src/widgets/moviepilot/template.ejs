<div class="relative w-full h-full rounded-2xl overflow-hidden bg-white border-2 border-black flex items-center justify-evenly px-4">
  <div class="absolute top-2 left-3">
    <span class="text-black text-[9px] font-black tracking-widest uppercase opacity-40">MoviePilot</span>
  </div>
  <% 
    const keys = Object.keys(stats);
    const labelMap = { movie_subscribes: '电影', tv_subscribes: '剧集', downloading: '下载', seeding: '做种' };
    for(let i=0; i<Math.min(keys.length, 4); i++) { 
      const key = keys[i];
  %>
    <div class="flex flex-col items-center mt-2">
      <span class="text-2xl font-black text-black leading-none"><%= stats[key] %></span>
      <span class="text-[9px] text-gray-500 font-bold uppercase tracking-widest mt-1"><%= labelMap[key] || key %></span>
    </div>
  <% } %>
</div>
