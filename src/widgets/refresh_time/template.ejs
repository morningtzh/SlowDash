<% if (config.size === '2x1') { %>
  <div class="flex items-center justify-center gap-4 w-full h-full">
    <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">最后刷新时间</span>
    <span class="text-3xl font-black tabular-nums"><%= time %></span>
  </div>
<% } else { %>
  <div class="flex flex-col items-center justify-center w-full h-full p-2 text-center">
    <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">最后刷新</span>
    <span class="text-2xl font-black tabular-nums mt-1"><%= time %></span>
  </div>
<% } %>
