<div class="relative w-full h-full rounded-2xl overflow-hidden bg-white border-2 border-black flex items-center justify-evenly px-2">
  <div class="absolute top-2 left-3">
    <span class="text-black text-[9px] font-black tracking-widest uppercase opacity-40">WeRead</span>
  </div>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="text-black font-bold text-sm mt-3"><%= error %></div>
  <% } else { %>
    <div class="flex flex-col items-center mt-2">
      <span class="text-2xl font-black text-black leading-none"><%= readTime %></span>
      <span class="text-[9px] text-gray-500 font-bold tracking-widest mt-1">总阅读</span>
    </div>
    <div class="w-px h-6 bg-gray-300 mt-2"></div>
    <div class="flex flex-col items-center mt-2">
      <span class="text-2xl font-black text-black leading-none"><%= readDays %></span>
      <span class="text-[9px] text-gray-500 font-bold tracking-widest mt-1">天连续</span>
    </div>
    <div class="w-px h-6 bg-gray-300 mt-2"></div>
    <div class="flex flex-col items-center mt-2">
      <span class="text-2xl font-black text-black leading-none"><%= booksCount %></span>
      <span class="text-[9px] text-gray-500 font-bold tracking-widest mt-1">本读过</span>
    </div>
  <% } %>
</div>
