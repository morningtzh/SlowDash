<% if (type === 'background') { %>
  <!-- Type: background -->
  <div class="relative w-full h-full bg-white flex items-center justify-center">
    <div class="absolute inset-0 bg-cover bg-center mix-blend-multiply opacity-20" style="background-image: url('<%= imageUrl %>'); filter: grayscale(100%) contrast(1.2);"></div>
    <div class="absolute bottom-4 right-4 bg-white text-black px-2 py-0.5 text-[9px] font-black tracking-widest uppercase rounded-sm border-2 border-black">ART</div>
  </div>
<% } else { %>
  <!-- Type: gallery -->
  <div class="relative w-full h-full overflow-hidden bg-white">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('<%= imageUrl %>'); filter: grayscale(100%) contrast(1.2) brightness(0.95);"></div>
    <div class="absolute top-4 left-4">
      <span class="bg-white text-black px-2 py-1 text-[9px] font-black uppercase tracking-widest shadow-sm rounded-sm">Gallery</span>
    </div>
  </div>
<% } %>
