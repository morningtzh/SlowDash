<% if (typeof error !== 'undefined' && error) { %>
  <div class="w-full h-full p-4 flex flex-col items-center justify-center">
    <span class="text-sm font-bold text-black">Github Chart Error</span>
    <span class="text-xs break-all"><%= error %></span>
  </div>
<% } else if (config.type === 'heatmap' || !config.type) { %>
  <!-- Type: heatmap -->
  <% if (config.size === '4x1' || config.size === '3x1' || config.size === '5x1') { %>
    <!-- Extremely compact, just the chart -->
    <div class="w-full h-full p-2 flex items-center justify-center overflow-hidden grayscale">
      <%- svg %>
    </div>
  <% } else { %>
    <!-- Standard layout with label -->
    <div class="relative w-full h-full p-4 flex flex-col justify-center">
      <div class="text-[10px] font-black uppercase tracking-widest text-gray-400 opacity-60 mb-2 truncate max-w-[80%]">GITHUB: <%= username %></div>
      <div class="flex-grow w-full min-h-0 overflow-hidden flex items-center justify-center grayscale">
        <%- svg %>
      </div>
    </div>
  <% } %>
<% } else { %>
  <!-- Type: stats -->
  <div class="relative w-full h-full p-4 flex flex-col justify-center items-center overflow-hidden">
    <div class="absolute top-3 left-3 text-[9px] font-black tracking-widest uppercase text-gray-400 opacity-60">GITHUB</div>
    <span class="text-5xl font-black tabular-nums tracking-tighter leading-none text-black"><%= typeof total !== 'undefined' ? total : 0 %></span>
    <span class="text-[9px] font-bold uppercase tracking-widest text-gray-500 mt-2 whitespace-nowrap">Contributions</span>
  </div>
<% } %>
