<% if (type === 'multiple') { %>
  <div class="relative p-3 w-full h-full flex flex-col bg-white rounded-2xl border-2 border-black">
    <div class="absolute top-2 left-3">
      <span class="text-black text-[9px] font-black tracking-widest uppercase opacity-40">Events</span>
    </div>
    <div class="flex-grow grid grid-cols-2 gap-2 mt-4">
      <% events.slice(0, 4).forEach(ev => { %>
        <div class="bg-black text-white rounded-xl flex flex-col justify-center items-center p-2">
          <span class="text-[9px] font-bold tracking-widest uppercase"><%= ev.name %></span>
          <span class="text-3xl font-black mt-1"><%= Math.abs(ev.days) %></span>
        </div>
      <% }) %>
    </div>
  </div>
<% } else { %>
  <!-- Single -->
  <div class="relative p-3 w-full h-full flex flex-col items-center justify-center bg-black text-white rounded-2xl border-2 border-black">
    <div class="absolute top-2 left-2">
      <span class="text-white text-[8px] font-black tracking-widest uppercase opacity-50">
        <%= event_type === 'anniversary' ? 'Anniversary' : 'Countdown' %>
      </span>
    </div>
    <div class="flex items-baseline gap-1 mt-3">
      <span class="text-4xl font-black tracking-tighter"><%= days %></span>
      <span class="text-sm font-bold">天</span>
    </div>
    <p class="text-[10px] font-bold tracking-widest mt-1 text-gray-300 uppercase"><%= name %></p>
  </div>
<% } %>
