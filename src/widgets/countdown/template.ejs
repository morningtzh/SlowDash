<% if (type === 'multiple') { %>
  <div class="relative w-full h-full p-5 flex flex-col bg-white">
    <div class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mb-4">Countdowns</div>
    <div class="flex-grow flex flex-col justify-start gap-3 overflow-hidden">
      <% events.slice(0, 5).forEach(ev => { %>
        <div class="flex justify-between items-center border-b border-gray-100 last:border-0 pb-1">
          <span class="text-lg font-bold truncate max-w-[65%] min-w-0 text-black"><%= ev.name %></span>
          <div class="flex items-baseline flex-shrink-0">
            <span class="text-2xl font-black tabular-nums text-black"><%= Math.abs(ev.days) %></span>
            <span class="text-[9px] font-bold text-gray-500 ml-1">天</span>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
<% } else if (type === 'highlight') { %>
  <!-- Highlight (e.g. 2x2, 2x3) -->
  <div class="relative w-full h-full p-6 flex flex-col justify-center items-center bg-black text-white">
    <div class="absolute top-4 left-4 text-[9px] font-black uppercase tracking-widest opacity-50">
      <%= event_type === 'anniversary' ? 'Anniversary' : 'Countdown' %>
    </div>
    <div class="flex items-baseline gap-2 mt-4">
      <span class="text-7xl font-black tabular-nums tracking-tighter"><%= days %></span>
      <span class="text-sm font-bold">天</span>
    </div>
    <span class="text-sm font-bold tracking-widest mt-2 uppercase truncate max-w-full"><%= name %></span>
  </div>
<% } else { %>
  <!-- Single -->
  <% if (config.size === '1x2') { %>
    <div class="relative w-full h-full p-4 flex flex-col justify-between items-center text-center">
      <div class="text-[9px] font-black uppercase tracking-widest text-gray-400 opacity-60">
        <%= event_type === 'anniversary' ? 'Anniversary' : 'Countdown' %>
      </div>
      <div class="flex-grow flex flex-col justify-center items-center">
        <span class="text-6xl font-black tabular-nums tracking-tighter text-black"><%= days %></span>
        <span class="text-[9px] font-bold text-black mt-1">天</span>
      </div>
      <div class="text-[10px] font-bold text-black uppercase tracking-widest line-clamp-2 break-all"><%= name %></div>
    </div>
  <% } else { %>
    <!-- Default 1x1 -->
    <div class="relative w-full h-full p-3 flex flex-col items-center justify-center text-center">
      <div class="absolute top-2 left-2 text-[8px] font-black uppercase tracking-widest text-gray-400 opacity-60">
        <%= event_type === 'anniversary' ? 'Anniversary' : 'Countdown' %>
      </div>
      <div class="flex items-baseline gap-1 mt-4">
        <span class="text-4xl font-black tabular-nums tracking-tighter text-black"><%= days %></span>
        <span class="text-[8px] font-bold text-black">天</span>
      </div>
      <div class="text-[10px] font-bold text-black uppercase tracking-widest truncate w-full mt-2"><%= name %></div>
    </div>
  <% } %>
<% } %>
