<% if (type === 'quote') { %>
  <!-- Type: quote -->
  <% 
    let lineClamp = 'line-clamp-4';
    if (config.size === '3x2' || config.size === '4x2') lineClamp = 'line-clamp-5';
    if (config.size === '5x1') lineClamp = 'line-clamp-2';
  %>
  <div class="flex flex-col justify-between w-full h-full p-5 border-l-8 border-black overflow-hidden">
    <p class="text-2xl font-serif font-black leading-relaxed text-black break-all <%= lineClamp %>">
      <%= text %>
    </p>
    <p class="text-right text-lg text-gray-500 font-bold max-w-[80%] self-end truncate mt-2">
      —— <%= author %>
    </p>
  </div>
<% } else if (type === 'quote_vertical') { %>
  <!-- Type: quote_vertical -->
  <div class="relative w-full h-full p-5 pl-12 border-r-8 border-black overflow-hidden" style="writing-mode: vertical-rl; text-orientation: mixed;">
    <p class="text-2xl font-serif font-black leading-relaxed text-black break-all">
      <%= text %>
    </p>
    <p class="absolute bottom-5 left-4 text-lg text-gray-500 font-bold max-h-[80%] truncate">
      —— <%= author %>
    </p>
  </div>
<% } else if (type === 'minimal_vertical') { %>
  <!-- Type: minimal_vertical -->
  <div class="flex justify-center items-center w-full h-full p-4 overflow-hidden text-center" style="writing-mode: vertical-rl; text-orientation: mixed;">
    <p class="text-xl font-serif font-black text-black break-words overflow-hidden max-w-full"><%= text %></p>
    <p class="text-base text-gray-500 font-bold truncate mt-2">—— <%= author %></p>
  </div>
<% } else { %>
  <!-- Type: minimal -->
  <div class="flex flex-col justify-center items-center w-full h-full p-4 overflow-hidden text-center">
    <% if (config.size === '2x1') { %>
      <p class="text-lg font-serif font-black text-black break-all line-clamp-1 w-full"><%= text %></p>
      <p class="text-sm text-gray-500 font-bold max-w-[80%] truncate mt-1">—— <%= author %></p>
    <% } else { %>
      <p class="text-xl font-serif font-black text-black break-all line-clamp-2 w-full"><%= text %></p>
      <p class="text-base text-gray-500 font-bold max-w-[80%] truncate mt-2">—— <%= author %></p>
    <% } %>
  </div>
<% } %>
