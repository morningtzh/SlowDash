<div class="p-6 w-full h-full flex flex-col bg-white border-2 border-black rounded-3xl">
  <div class="flex justify-between items-center mb-4 border-b-2 border-black pb-2">
    <h3 class="text-xl font-bold uppercase">Upcoming</h3>
    <span class="text-sm font-bold bg-black text-white px-2 py-1 rounded-full">iCloud</span>
  </div>
  <div class="flex-grow flex flex-col gap-3 justify-center">
    <% events.forEach(function(ev){ %>
      <div class="flex justify-between items-center border-b border-gray-100 last:border-0 pb-1">
        <span class="text-lg font-medium truncate max-w-[60%]"><%= ev.title %></span>
        <span class="text-gray-500 font-bold text-right"><%= ev.time %></span>
      </div>
    <% }); %>
  </div>
</div>
