<% if (type === 'today') { %>
  <!-- Type: today -->
  <% if (config.size === '2x1') { %>
    <div class="relative w-full h-full p-4 flex flex-col justify-between bg-white text-black">
      <div class="flex justify-between items-center border-b-2 border-black pb-2">
        <span class="text-xl font-black uppercase tracking-widest">NEXT</span>
        <span class="text-xl font-black tabular-nums"><%= events[0] ? events[0].time : '' %></span>
      </div>
      <div class="text-2xl font-bold truncate max-w-full"><%= events[0] ? events[0].title : '无待办' %></div>
    </div>
  <% } else { %>
    <div class="w-full h-full p-4 flex flex-col gap-4 bg-white text-black justify-center">
      <% events.slice(0, 3).forEach(function(ev){ %>
        <div class="flex flex-col border-l-4 border-black pl-2">
          <span class="text-[10px] font-bold text-gray-500 tabular-nums uppercase"><%= ev.time %></span>
          <span class="text-sm font-bold truncate mt-1 max-w-[120px]"><%= ev.title %></span>
        </div>
      <% }); %>
    </div>
  <% } %>
<% } else { %>
  <!-- Type: agenda -->
  <div class="flex flex-col w-full h-full p-5 bg-white text-black">
    <div class="flex justify-between items-center mb-4 border-b-2 border-black pb-2">
      <span class="text-sm font-bold uppercase tracking-widest">UPCOMING</span>
      <span class="text-[9px] bg-black text-white px-2 py-0.5 rounded font-bold">iCloud</span>
    </div>
    <div class="flex-grow flex flex-col justify-start gap-4 overflow-hidden">
      <% events.forEach(function(ev){ %>
        <div class="flex justify-between items-center">
          <span class="text-lg font-bold truncate max-w-[65%] min-w-0"><%= ev.title %></span>
          <span class="text-sm font-black text-right flex-shrink-0 tabular-nums"><%= ev.time %></span>
        </div>
      <% }); %>
    </div>
  </div>
<% } %>
